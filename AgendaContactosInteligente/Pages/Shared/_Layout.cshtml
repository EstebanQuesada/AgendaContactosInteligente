<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AgendaContactosInteligente</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AgendaContactosInteligente.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">

    <header>
        <nav class="navbar navbar-expand-lg app-navbar app-navbar-enhanced sticky-top">
            <div class="container">
                <a class="navbar-brand app-brand app-brand-enhanced" asp-page="/Index">
                    <span class="brand-mark">AC</span>
                    <span class="brand-text-wrap">
                        <span class="brand-title">Agenda Contactos Inteligente</span>
                        <small class="brand-subtitle">Gestión clara y moderna</small>
                    </span>
                </a>

                <button class="navbar-toggler border-0 shadow-none app-navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Mostrar navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2 app-nav-list">
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-page="/Index">Inicio</a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle app-nav-link"
                               href="#"
                               id="contactosDropdown"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Contactos
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end app-dropdown shadow-lg border-0"
                                aria-labelledby="contactosDropdown">
                                <li>
                                    <a class="dropdown-item app-dropdown-item" asp-page="/Contactos/Index">
                                        <span class="dropdown-item-title">Panel de contactos</span>
                                        <small class="dropdown-item-text">Accede al listado y administración</small>
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item app-dropdown-item" asp-page="/Contactos/Create">
                                        <span class="dropdown-item-title">Agregar contacto</span>
                                        <small class="dropdown-item-text">Registrar un nuevo contacto</small>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item app-dropdown-item" asp-page="/Contactos/Index">
                                        <span class="dropdown-item-title">Listado de contactos</span>
                                        <small class="dropdown-item-text">Consultar y administrar registros</small>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle app-nav-link"
                               href="#"
                               id="etiquetasDropdown"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Etiquetas
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end app-dropdown shadow-lg border-0"
                                aria-labelledby="etiquetasDropdown">
                                <li>
                                    <a class="dropdown-item app-dropdown-item" asp-page="/Etiquetas/Index">
                                        <span class="dropdown-item-title">Panel de etiquetas</span>
                                        <small class="dropdown-item-text">Accede al listado y administración</small>
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item app-dropdown-item" asp-page="/Etiquetas/Create">
                                        <span class="dropdown-item-title">Agregar etiqueta</span>
                                        <small class="dropdown-item-text">Registrar una nueva etiqueta</small>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item app-dropdown-item" asp-page="/Etiquetas/Index">
                                        <span class="dropdown-item-title">Listado de etiquetas</span>
                                        <small class="dropdown-item-text">Consultar y administrar etiquetas</small>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-page="/Privacy">Privacidad</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container app-main app-main-enhanced">
        @RenderBody()
    </main>

    <footer class="app-footer app-footer-enhanced mt-5">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="footer-brand-block">
                <div class="footer-title">&copy; 2026 - AgendaContactosInteligente</div>
                <div class="footer-mini-text">Gestión de contactos</div>
            </div>

            <div class="footer-links-mini">
                <a asp-page="/Index" class="footer-link-mini">Inicio</a>
                <a asp-page="/Contactos/Index" class="footer-link-mini">Contactos</a>
                <a asp-page="/Etiquetas/Index" class="footer-link-mini">Etiquetas</a>
                <a asp-page="/Privacy" class="footer-link-mini">Privacidad</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>