@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<div class="py-5 text-center">
    <h1 class="display-5 fw-bold">Agenda de Contactos Inteligente</h1>
    <p class="lead text-muted mt-3">
        Sistema de gestión de contactos con acceso a creación, consulta, edición y eliminación.
    </p>

    <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
        <a asp-page="/Contactos/Index" class="btn btn-primary btn-lg">
            Ver lista de contactos
        </a>

        <a asp-page="/Contactos/Create" class="btn btn-outline-primary btn-lg">
            Crear contacto
        </a>
    </div>
</div>