@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="text-center mt-5">

    <h1 class="display-4">
        Agenda de Contactos Inteligente
    </h1>

    <p class="lead">
        Sistema de gestión de contactos con búsqueda avanzada
    </p>

    <div class="mt-4">

        <a asp-page="/Contactos/Create"
           class="btn btn-primary btn-lg me-2">
            Nuevo Contacto
        </a>

        <a asp-page="/Contactos/Index"
           class="btn btn-outline-primary btn-lg">
            Ver Contactos
        </a>

    </div>

</div>