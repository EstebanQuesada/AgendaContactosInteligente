@page
@model AgendaContactosInteligente.Pages.Contactos.IndexModel
@{
    ViewData["Title"] = "Lista de contactos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Lista de contactos</h2>
        <p class="text-muted mb-0">Consulta y administra los contactos registrados.</p>
    </div>

    <a asp-page="/Contactos/Create" class="btn btn-primary">
        Nuevo contacto
    </a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success">
        @Model.SuccessMessage
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 90px;">Favorito</th>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th style="width: 180px;">Fecha creación</th>
                        <th class="text-end" style="width: 260px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Contactos.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                No hay contactos registrados.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var contacto in Model.Contactos)
                        {
                            <tr>
                                <td>
                                    @if (contacto.EsFavorito)
                                    {
                                        <span class="badge bg-warning text-dark">Sí</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No</span>
                                    }
                                </td>

                                <td>@contacto.Nombre</td>
                                <td>@(string.IsNullOrWhiteSpace(contacto.Apellido) ? "-" : contacto.Apellido)</td>
                                <td>@contacto.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>

                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-page="/Contactos/Details"
                                           asp-route-id="@contacto.ContactoID"
                                           class="btn btn-outline-secondary btn-sm">
                                            Ver
                                        </a>

                                        <a asp-page="/Contactos/Edit"
                                           asp-route-id="@contacto.ContactoID"
                                           class="btn btn-outline-primary btn-sm">
                                            Editar
                                        </a>

                                        <a asp-page="/Contactos/Delete"
                                           asp-route-id="@contacto.ContactoID"
                                           class="btn btn-outline-danger btn-sm">
                                            Eliminar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>