@page
@model AgendaContactosInteligente.Pages.Contactos.IndexModel
@{
    ViewData["Title"] = "Lista de contactos";
}

<section class="page-section fade-up contactos-page">
    <div class="page-header-card contact-hero-card mb-4">
        <div class="hero-pattern"></div>

        <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-4 position-relative">
            <div class="hero-copy">
                <div class="page-eyebrow">Contactos</div>
                <h1 class="page-title mb-2">Panel de contactos</h1>
                <p class="page-subtitle mb-0">
                    Consulta, administra y accede rápidamente a las acciones principales de tus contactos.
                </p>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-2 hero-actions-panel">
                <a asp-page="/Contactos/Create" class="btn btn-app-primary contact-main-cta">
                    <span class="btn-icon">＋</span>
                    <span>Nuevo contacto</span>
                </a>
            </div>
        </div>

        <div class="quick-access-grid quick-access-grid-enhanced mt-4">
            <a asp-page="/Contactos/Create" class="quick-access-card quick-access-card-enhanced">
                <div class="quick-access-icon qa-green">＋</div>
                <div>
                    <h3>Agregar contacto</h3>
                    <p>Registrar un nuevo contacto de forma rápida y ordenada.</p>
                </div>
            </a>

            <a asp-page="/Contactos/Index" class="quick-access-card quick-access-card-enhanced active">
                <div class="quick-access-icon qa-blue">☰</div>
                <div>
                    <h3>Listado</h3>
                    <p>Visualiza, organiza y administra todos los contactos registrados.</p>
                </div>
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success app-alert-success mb-4 shadow-sm">
            <div class="d-flex align-items-center gap-2">
                <span class="alert-mini-icon">✓</span>
                <span>@Model.SuccessMessage</span>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger mb-4 shadow-sm rounded-4 border-0">
            <div class="d-flex align-items-center gap-2">
                <span class="alert-mini-icon danger">!</span>
                <span>@Model.ErrorMessage</span>
            </div>
        </div>
    }

    <div class="card app-card border-0 mb-4 contact-filter-card">
        <div class="card-body p-4 p-lg-4">
            <div class="filter-card-header mb-3">
                <div>
                    <div class="form-top-label mb-1">Búsqueda inteligente</div>
                    <h2 class="h5 fw-bold mb-1">Filtrar contactos</h2>
                    <p class="text-muted mb-0">Busca por texto, corrige coincidencias aproximadas y filtra por provincia, correo, favoritos y etiquetas.</p>
                </div>
            </div>

            <form method="get" class="row g-3">
                <div class="col-12 col-xl-6">
                    <label asp-for="TextoBusqueda" class="form-label fw-semibold">Texto de búsqueda</label>
                    <input asp-for="TextoBusqueda" class="form-control rounded-4" placeholder="Nombre, apellido, correo, teléfono, nota o etiqueta" />
                    <div class="form-text">
                        La búsqueda admite coincidencias parciales y aproximadas.
                    </div>
                </div>

                <div class="col-12 col-md-6 col-xl-3">
                    <label asp-for="Provincia" class="form-label fw-semibold">Provincia</label>
                    <input asp-for="Provincia" class="form-control rounded-4" placeholder="Ej. San José" />
                </div>

                <div class="col-12 col-md-6 col-xl-3">
                    <label asp-for="TieneCorreo" class="form-label fw-semibold">Correo</label>
                    <select asp-for="TieneCorreo" class="form-select rounded-4 app-select-enhanced">
                        <option value="">Todos</option>
                        <option value="true">Con correo</option>
                        <option value="false">Sin correo</option>
                    </select>
                </div>

                <div class="col-12 col-md-6 col-xl-3">
                    <label asp-for="Favoritos" class="form-label fw-semibold">Favoritos</label>
                    <select asp-for="Favoritos" class="form-select rounded-4 app-select-enhanced">
                        <option value="">Todos</option>
                        <option value="true">Solo favoritos</option>
                        <option value="false">Solo no favoritos</option>
                    </select>
                </div>

                <div class="col-12 col-xl-9">
                    <label asp-for="EtiquetaIds" class="form-label fw-semibold">Etiquetas</label>
                    <select asp-for="EtiquetaIds" class="form-select rounded-4 app-select-enhanced" multiple size="5">
                        @foreach (var etiqueta in Model.Etiquetas)
                        {
                            <option value="@etiqueta.EtiquetaID">@etiqueta.Nombre</option>
                        }
                    </select>
                    <div class="form-text">
                        Puedes seleccionar una o varias etiquetas.
                    </div>
                </div>

                <div class="col-12">
                    <div class="d-flex flex-column flex-sm-row gap-2 filter-actions">
                        <button type="submit" class="btn btn-app-primary px-4">
                            Buscar y filtrar
                        </button>

                        <a asp-page="/Contactos/Index" class="btn btn-app-outline px-4">
                            Limpiar filtros
                        </a>
                    </div>
                </div>
            </form>

            @if (Model.TieneFiltrosActivos())
            {
                <div class="active-filter-panel mt-4 d-flex flex-wrap gap-2 align-items-center">
                    <span class="active-filter-label">Filtros activos</span>

                    @if (!string.IsNullOrWhiteSpace(Model.CriteriosAplicados.TextoBusqueda))
                    {
                        <span class="active-filter-badge">Texto: @Model.CriteriosAplicados.TextoBusqueda</span>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.CriteriosAplicados.Provincia))
                    {
                        <span class="active-filter-badge">Provincia: @Model.CriteriosAplicados.Provincia</span>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.ObtenerTextoTieneCorreo()))
                    {
                        <span class="active-filter-badge">@Model.ObtenerTextoTieneCorreo()</span>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.ObtenerTextoFavoritos()))
                    {
                        <span class="active-filter-badge">@Model.ObtenerTextoFavoritos()</span>
                    }

                    @if (Model.EtiquetasSeleccionadas.Any())
                    {
                        foreach (var etiqueta in Model.EtiquetasSeleccionadas)
                        {
                            <span class="active-filter-badge" style="background-color:@etiqueta.ColorHex; color:#ffffff;">
                                @etiqueta.Nombre
                            </span>
                        }
                    }
                </div>
            }
        </div>
    </div>

    <div class="card app-card border-0 mb-4">
        <div class="card-body d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <div class="fw-semibold text-dark">@Model.ObtenerResumenResultados()</div>
                <div class="text-muted small">
                    @(Model.TieneBusquedaPorTexto()
                                        ? "Los resultados se ordenan con ranking interno y se muestran con porcentaje visible limpio."
                                        : "Puedes usar la búsqueda inteligente para encontrar contactos más rápido.")
                </div>
            </div>

            @if (Model.TieneBusquedaPorTexto())
            {
                <div class="badge rounded-pill px-3 py-2" style="background-color:#eef4ff; color:#1d4ed8;">
                    Coincidencia porcentual activa
                </div>
            }
        </div>
    </div>

    @if (Model.TieneBusquedaPorTexto())
    {
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-4">
                <div class="card app-card border-0 h-100">
                    <div class="card-body">
                        <div class="small text-muted mb-1">Alta coincidencia</div>
                        <div class="fs-4 fw-bold text-success">@Model.TotalAltaCoincidencia</div>
                        <div class="small text-muted">Resultados entre 85% y 100%</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="card app-card border-0 h-100">
                    <div class="card-body">
                        <div class="small text-muted mb-1">Media coincidencia</div>
                        <div class="fs-4 fw-bold" style="color:#b45309;">@Model.TotalMediaCoincidencia</div>
                        <div class="small text-muted">Resultados entre 65% y 84%</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="card app-card border-0 h-100">
                    <div class="card-body">
                        <div class="small text-muted mb-1">Baja coincidencia</div>
                        <div class="fs-4 fw-bold text-danger">@Model.TotalBajaCoincidencia</div>
                        <div class="small text-muted">Resultados entre 1% y 64%</div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="card app-card border-0 contact-table-card overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table app-table contact-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 120px;">Favorito</th>
                            <th>Nombre</th>
                            <th>Apellido</th>
                            <th style="width: 170px;">Coincidencia</th>
                            <th style="width: 190px;">Nivel</th>
                            <th style="min-width: 240px;">Motivo principal</th>
                            <th style="min-width: 260px;">Campos coincidentes</th>
                            <th style="min-width: 260px;">Etiquetas</th>
                            <th style="width: 210px;">Fecha creación</th>
                            <th class="text-end" style="width: 290px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ResultadosBusqueda.Any())
                        {
                            <tr>
                                <td colspan="10" class="text-center py-5 text-muted">
                                    <div class="empty-state-table empty-state-table-enhanced">
                                        <div class="empty-state-icon">⌁</div>
                                        <div class="fw-semibold mb-1 fs-6">No hay contactos para mostrar</div>
                                        <div class="small empty-state-text">
                                            @(Model.TieneFiltrosActivos()
                                                                                    ? "No se encontraron contactos con los filtros aplicados."
                                                                                    : "Cuando agregues contactos aparecerán aquí.")
                                    </div>

                                        <div class="mt-3">
                                            <a asp-page="/Contactos/Create" class="btn btn-app-primary btn-sm px-4">
                                                Crear contacto
                                            </a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                                                }
                        else
                        {
                            foreach (var resultado in Model.ResultadosBusqueda)
                            {
                                var contacto = resultado.Contacto;

                                <tr class="contact-row">
                                    <td>
                                        @if (contacto.EsFavorito)
                                        {
                                            <span class="badge favorite-badge contact-status-badge">
                                                ★ Favorito
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge normal-badge contact-status-badge">
                                                Normal
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        <div class="contact-name-cell">
                                            <div class="contact-avatar">
                                                @(string.IsNullOrWhiteSpace(contacto.Nombre) ? "?" : contacto.Nombre.Substring(0, 1).ToUpper())
                                            </div>
                                            <div>
                                                <div class="fw-semibold text-dark">@contacto.Nombre</div>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="text-body-secondary">
                                            @(string.IsNullOrWhiteSpace(contacto.Apellido) ? "-" : contacto.Apellido)
                                        </span>
                                    </td>

                                    <td>
                                        @if (Model.TieneBusquedaPorTexto())
                                        {
                                            <span class="badge rounded-pill px-3 py-2" style="background-color:#ecfdf5; color:#047857;">
                                                @resultado.PuntajeFormateado
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <td>
                                        @if (Model.TieneBusquedaPorTexto())
                                        {
                                            @if (resultado.NivelCoincidencia == "Alta")
                                            {
                                                <span class="badge rounded-pill px-3 py-2" style="background-color:#dcfce7; color:#166534;">
                                                    @resultado.NivelCoincidenciaTexto
                                                </span>
                                            }
                                            else if (resultado.NivelCoincidencia == "Media")
                                            {
                                                <span class="badge rounded-pill px-3 py-2" style="background-color:#fef3c7; color:#92400e;">
                                                    @resultado.NivelCoincidenciaTexto
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill px-3 py-2" style="background-color:#fee2e2; color:#991b1b;">
                                                    @resultado.NivelCoincidenciaTexto
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <td>
                                        @if (Model.TieneBusquedaPorTexto())
                                        {
                                            <span class="text-body-secondary fw-semibold">
                                                @resultado.MotivoPrincipal
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>

                                    <td>
                                        @if (resultado.CamposCoincidenciaOrdenados.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-2">
                                                @foreach (var campo in resultado.CamposCoincidenciaOrdenados)
                                                {
                                                    <span class="badge rounded-pill px-3 py-2" style="background-color:#f3f4f6; color:#374151;">
                                                        @campo
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="contact-empty-label">Sin coincidencias destacadas</span>
                                        }
                                    </td>

                                    <td>
                                        @if (contacto.Etiquetas.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-2">
                                                @foreach (var etiqueta in contacto.Etiquetas)
                                                {
                                                    <span class="contact-tag-link badge rounded-pill text-decoration-none px-3 py-2"
                                                          style="background-color:@etiqueta.ColorHex; color:#ffffff;">
                                                        @etiqueta.Nombre
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="contact-empty-label">Sin etiquetas</span>
                                        }
                                    </td>

                                    <td class="text-muted">
                                        <div class="date-block">
                                            <span>@contacto.FechaCreacion.ToString("dd/MM/yyyy")</span>
                                            <small>@contacto.FechaCreacion.ToString("HH:mm")</small>
                                        </div>
                                    </td>

                                    <td class="text-end">
                                        <div class="d-flex justify-content-end flex-wrap gap-2">
                                            <a asp-page="/Contactos/Details"
                                               asp-route-id="@contacto.ContactoID"
                                               class="btn btn-sm btn-action btn-action-neutral">
                                                Ver
                                            </a>

                                            <a asp-page="/Contactos/Edit"
                                               asp-route-id="@contacto.ContactoID"
                                               class="btn btn-sm btn-action btn-action-primary">
                                                Editar
                                            </a>

                                            <a asp-page="/Contactos/Delete"
                                               asp-route-id="@contacto.ContactoID"
                                               class="btn btn-sm btn-action btn-action-danger">
                                                Eliminar
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (Model.TienePaginacion())
    {
        <div class="card app-card border-0 mt-4">
            <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div class="text-muted small">
                    Página @Model.PageNumber de @Model.TotalPaginas · @Model.TotalResultados resultado(s)
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <a asp-page="/Contactos/Index"
                       asp-route-TextoBusqueda="@Model.TextoBusqueda"
                       asp-route-Provincia="@Model.Provincia"
                       asp-route-TieneCorreo="@Model.TieneCorreo"
                       asp-route-Favoritos="@Model.Favoritos"
                       asp-route-PageNumber="@Model.PaginaAnterior()"
                       asp-route-EtiquetaIds="@Model.EtiquetaIds"
                       class="btn btn-app-outline @(Model.PageNumber <= 1 ? "disabled" : "")">
                        Anterior
                    </a>

                    <a asp-page="/Contactos/Index"
                       asp-route-TextoBusqueda="@Model.TextoBusqueda"
                       asp-route-Provincia="@Model.Provincia"
                       asp-route-TieneCorreo="@Model.TieneCorreo"
                       asp-route-Favoritos="@Model.Favoritos"
                       asp-route-PageNumber="@Model.PaginaSiguiente()"
                       asp-route-EtiquetaIds="@Model.EtiquetaIds"
                       class="btn btn-app-outline @(Model.PageNumber >= Model.TotalPaginas ? "disabled" : "")">
                        Siguiente
                    </a>
                </div>
            </div>
        </div>
    }
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const rows = document.querySelectorAll(".contact-row");
            rows.forEach((row, index) => {
                row.style.opacity = "0";
                row.style.transform = "translateY(10px)";
                row.style.transition = "opacity 0.35s ease, transform 0.35s ease";
                setTimeout(() => {
                    row.style.opacity = "1";
                    row.style.transform = "translateY(0)";
                }, 60 * index);
            });
        });
    </script>
}