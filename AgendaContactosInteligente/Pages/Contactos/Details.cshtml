@page "{id:int}"
@model AgendaContactosInteligente.Pages.Contactos.DetailsModel
@{
    ViewData["Title"] = "Detalle del contacto";
}

<div class="row justify-content-center py-2 py-lg-4 fade-up contact-details-page">
    <div class="col-12 col-xl-10">
        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="alert alert-success app-alert-success mb-4">
                <div class="d-flex align-items-center gap-2">
                    <span class="alert-mini-icon">✓</span>
                    <span>@Model.SuccessMessage</span>
                </div>
            </div>
        }

        <div class="card app-card border-0 overflow-hidden">
            <div class="card-header app-detail-header py-4 px-4 px-lg-5 detail-hero-header">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
                    <div class="detail-hero-copy">
                        <div class="page-eyebrow">Detalle del contacto</div>
                        <h1 class="page-title h3 mb-2">@Model.Contacto!.Nombre @Model.Contacto.Apellido</h1>

                        <div class="detail-meta-row">
                            <span class="detail-meta-pill">
                                Creado el @Model.Contacto.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-sm-row gap-2">
                        <a asp-page="Edit"
                           asp-route-id="@Model.Contacto.ContactoID"
                           class="btn btn-app-primary px-4">
                            Editar
                        </a>

                        <a asp-page="Delete"
                           asp-route-id="@Model.Contacto.ContactoID"
                           class="btn btn-app-outline px-4">
                            Eliminar
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-4 p-lg-5">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="section-card h-100 detail-section-card">
                            <h2 class="section-title">Datos generales</h2>

                            <div class="detail-stat-row">
                                <span class="fw-semibold">Favorito</span>
                                <span class="info-chip @(Model.Contacto.EsFavorito ? "chip-favorite" : "chip-normal")">
                                    @(Model.Contacto.EsFavorito ? "Sí" : "No")
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="section-card h-100 detail-section-card">
                            <h2 class="section-title">Etiquetas</h2>

                            @if (Model.EtiquetasContacto.Any())
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var etiqueta in Model.EtiquetasContacto)
                                    {
                                        <a asp-page="/Contactos/Index"
                                           asp-route-EtiquetaId="@etiqueta.EtiquetaID"
                                           class="badge rounded-pill text-decoration-none px-3 py-2 detail-tag-link"
                                           style="background-color:@etiqueta.ColorHex; color:#ffffff;">
                                            @etiqueta.Nombre
                                        </a>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">Sin etiquetas asociadas.</p>
                            }
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="section-card h-100 detail-section-card">
                            <h2 class="section-title">Teléfonos</h2>

                            @if (Model.Contacto.Telefonos.Any())
                            {
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var telefono in Model.Contacto.Telefonos)
                                    {
                                        <div class="note-box detail-info-box">
                                            <span class="fw-semibold">@telefono.Numero</span>
                                            <span class="text-muted ms-1">(@telefono.Tipo)</span>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">Sin teléfonos registrados.</p>
                            }
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="section-card h-100 detail-section-card">
                            <h2 class="section-title">Correos</h2>

                            @if (Model.Contacto.Correos.Any())
                            {
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var correo in Model.Contacto.Correos)
                                    {
                                        <div class="note-box detail-info-box">
                                            @correo.Email
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">Sin correos registrados.</p>
                            }
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="section-card h-100 detail-section-card">
                            <h2 class="section-title">Dirección</h2>

                            @if (Model.Contacto.Direccion is not null)
                            {
                                <div class="detail-address-grid">
                                    <div class="detail-key-value">
                                        <span class="detail-kv-label">Provincia</span>
                                        <span class="detail-kv-value">@Model.Contacto.Direccion.Provincia</span>
                                    </div>

                                    <div class="detail-key-value">
                                        <span class="detail-kv-label">Cantón</span>
                                        <span class="detail-kv-value">@Model.Contacto.Direccion.Canton</span>
                                    </div>

                                    <div class="detail-key-value">
                                        <span class="detail-kv-label">Distrito</span>
                                        <span class="detail-kv-value">@Model.Contacto.Direccion.Distrito</span>
                                    </div>

                                    <div class="detail-key-value detail-key-value-full">
                                        <span class="detail-kv-label">Dirección exacta</span>
                                        <span class="detail-kv-value">@Model.Contacto.Direccion.DireccionExacta</span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">Sin dirección registrada.</p>
                            }
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="section-card detail-section-card">
                            <h2 class="section-title">Notas</h2>

                            @if (Model.Contacto.Notas.Any())
                            {
                                <div class="d-flex flex-column gap-3">
                                    @foreach (var nota in Model.Contacto.Notas)
                                    {
                                        <div class="note-box detail-note-box">
                                            @nota.Contenido
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">Sin notas registradas.</p>
                            }
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-2">
                    <a asp-page="Index" class="btn btn-app-outline px-4">
                        Volver al panel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>