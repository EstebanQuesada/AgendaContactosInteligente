@page "{id:int}"
@model AgendaContactosInteligente.Pages.Contactos.EditModel
@{
    ViewData["Title"] = "Editar contacto";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h2 class="h4 mb-0">Editar contacto</h2>
                    <a asp-page="Details" asp-route-id="@Model.Input.ContactoID" class="btn btn-outline-secondary btn-sm">Volver</a>
                </div>
                <div class="card-body">
                    <form method="post" novalidate>
                        <input asp-for="Input.ContactoID" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Input.Nombre" class="form-label"></label>
                                <input asp-for="Input.Nombre" class="form-control" />
                                <span asp-validation-for="Input.Nombre" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.Apellido" class="form-label"></label>
                                <input asp-for="Input.Apellido" class="form-control" />
                                <span asp-validation-for="Input.Apellido" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <div class="form-check mt-2">
                                    <input asp-for="Input.EsFavorito" class="form-check-input" />
                                    <label asp-for="Input.EsFavorito" class="form-check-label"></label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.TelefonoNumero" class="form-label">Teléfono</label>
                                <input asp-for="Input.TelefonoNumero" class="form-control" />
                                <span asp-validation-for="Input.TelefonoNumero" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Input.TelefonoTipo" class="form-label">Tipo de teléfono</label>
                                <input asp-for="Input.TelefonoTipo" class="form-control" />
                                <span asp-validation-for="Input.TelefonoTipo" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Input.Email" class="form-label">Correo</label>
                                <input asp-for="Input.Email" class="form-control" />
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Input.Provincia" class="form-label"></label>
                                <input asp-for="Input.Provincia" class="form-control" />
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Input.Canton" class="form-label"></label>
                                <input asp-for="Input.Canton" class="form-control" />
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Input.Distrito" class="form-label"></label>
                                <input asp-for="Input.Distrito" class="form-control" />
                            </div>

                            <div class="col-12">
                                <label asp-for="Input.DireccionExacta" class="form-label">Dirección exacta</label>
                                <textarea asp-for="Input.DireccionExacta" class="form-control" rows="3"></textarea>
                            </div>

                            <div class="col-12">
                                <label asp-for="Input.NotaContenido" class="form-label">Nota</label>
                                <textarea asp-for="Input.NotaContenido" class="form-control" rows="4"></textarea>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-page="Details" asp-route-id="@Model.Input.ContactoID" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Guardar cambios</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}