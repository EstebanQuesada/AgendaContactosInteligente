@page
@model AgendaContactosInteligente.Pages.Contactos.CreateModel
@{
    ViewData["Title"] = "Nuevo contacto";
}

<div class="container py-4 py-lg-5 fade-up">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="card app-form-card border-0 overflow-hidden">
                <div class="card-header app-form-header">
                    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                        <div>
                            <p class="form-top-label mb-1">Agenda inteligente</p>
                            <h1 class="h3 mb-1 fw-bold">Registrar contacto</h1>
                            <p class="text-muted mb-0">Completa la información del nuevo contacto.</p>
                        </div>

                        <a asp-page="/Contactos/Index" class="btn btn-app-outline rounded-pill px-4">
                            Volver al panel
                        </a>
                    </div>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <form method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="row g-4">
                            <div class="col-12">
                                <div class="form-section-box form-section-highlight">
                                    <h2 class="form-section-title">Información principal</h2>

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label asp-for="Input.Nombre" class="form-label fw-semibold"></label>
                                            <input asp-for="Input.Nombre" class="form-control form-control-lg rounded-3" />
                                            <span asp-validation-for="Input.Nombre" class="text-danger small"></span>
                                        </div>

                                        <div class="col-md-6">
                                            <label asp-for="Input.Apellido" class="form-label fw-semibold"></label>
                                            <input asp-for="Input.Apellido" class="form-control form-control-lg rounded-3" />
                                            <span asp-validation-for="Input.Apellido" class="text-danger small"></span>
                                        </div>

                                        <div class="col-12">
                                            <div class="form-check form-switch mt-1 app-switch">
                                                <input asp-for="Input.EsFavorito" class="form-check-input" />
                                                <label asp-for="Input.EsFavorito" class="form-check-label fw-semibold"></label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-section-box">
                                    <h2 class="form-section-title">Contacto</h2>

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label asp-for="Input.TelefonoNumero" class="form-label fw-semibold">Teléfono</label>
                                            <input asp-for="Input.TelefonoNumero" class="form-control rounded-3" />
                                            <span asp-validation-for="Input.TelefonoNumero" class="text-danger small"></span>
                                        </div>

                                        <div class="col-md-6">
                                            <label asp-for="Input.TelefonoTipo" class="form-label fw-semibold">Tipo de teléfono</label>
                                            <input asp-for="Input.TelefonoTipo" class="form-control rounded-3" />
                                            <span asp-validation-for="Input.TelefonoTipo" class="text-danger small"></span>
                                        </div>

                                        <div class="col-12">
                                            <label asp-for="Input.Email" class="form-label fw-semibold">Correo</label>
                                            <input asp-for="Input.Email" class="form-control rounded-3" />
                                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-section-box">
                                    <h2 class="form-section-title">Dirección</h2>

                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <label asp-for="Input.Provincia" class="form-label fw-semibold"></label>
                                            <input asp-for="Input.Provincia" class="form-control rounded-3" />
                                        </div>

                                        <div class="col-md-4">
                                            <label asp-for="Input.Canton" class="form-label fw-semibold"></label>
                                            <input asp-for="Input.Canton" class="form-control rounded-3" />
                                        </div>

                                        <div class="col-md-4">
                                            <label asp-for="Input.Distrito" class="form-label fw-semibold"></label>
                                            <input asp-for="Input.Distrito" class="form-control rounded-3" />
                                        </div>

                                        <div class="col-12">
                                            <label asp-for="Input.DireccionExacta" class="form-label fw-semibold">Dirección exacta</label>
                                            <textarea asp-for="Input.DireccionExacta" class="form-control rounded-3" rows="3"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-section-box">
                                    <h2 class="form-section-title">Información adicional</h2>

                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label asp-for="Input.NotaContenido" class="form-label fw-semibold">Nota</label>
                                            <textarea asp-for="Input.NotaContenido" class="form-control rounded-3" rows="4"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-column flex-sm-row justify-content-end gap-2 mt-4 pt-2">
                            <a asp-page="/Contactos/Index" class="btn btn-app-outline rounded-pill px-4">
                                Cancelar
                            </a>

                            <button type="submit" class="btn btn-app-primary rounded-pill px-4">
                                Guardar contacto
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}