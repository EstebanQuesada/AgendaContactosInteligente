@page
@model AgendaContactosInteligente.Pages.Contactos.CreateModel
@{
    ViewData["Title"] = "Nuevo contacto";
}

<div class="container py-4 py-lg-5 fade-up contact-form-page">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="card app-form-card border-0 overflow-hidden">
                <div class="card-header app-form-header contact-form-header">
                    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                        <div>
                            <p class="form-top-label mb-1">Gestión de contactos</p>
                            <h1 class="h3 mb-1 fw-bold">Nuevo contacto</h1>
                            <p class="text-muted mb-0">
                                Registra un nuevo contacto y asígnale etiquetas desde el inicio para una mejor organización.
                            </p>
                        </div>

                        <a asp-page="Index" class="btn btn-app-outline rounded-pill px-4">
                            Volver
                        </a>
                    </div>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <form method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4 validation-panel"></div>

                        <div class="row g-4">
                            <div class="col-12">
                                <div class="form-section-box form-section-highlight">
                                    <div class="section-headline-wrap">
                                        <h2 class="form-section-title">Información principal</h2>
                                        <p class="section-support-text mb-0">Datos base del contacto.</p>
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label asp-for="Input.Nombre" class="form-label fw-semibold"></label>
                                            <input asp-for="Input.Nombre" class="form-control form-control-lg rounded-3" placeholder="Ingresa el nombre" />
                                            <span asp-validation-for="Input.Nombre" class="text-danger small"></span>
                                        </div>

                                        <div class="col-md-6">
                                            <label asp-for="Input.Apellido" class="form-label fw-semibold"></label>
                                            <input asp-for="Input.Apellido" class="form-control form-control-lg rounded-3" placeholder="Ingresa el apellido" />
                                            <span asp-validation-for="Input.Apellido" class="text-danger small"></span>
                                        </div>

                                        <div class="col-12">
                                            <div class="form-check form-switch mt-1 app-switch contact-switch-box">
                                                <input asp-for="Input.EsFavorito" class="form-check-input" />
                                                <label asp-for="Input.EsFavorito" class="form-check-label fw-semibold"></label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-section-box">
                                    <div class="section-headline-wrap">
                                        <h2 class="form-section-title">Etiquetas</h2>
                                        <p class="section-support-text mb-0">Selecciona una o varias etiquetas para clasificar el contacto.</p>
                                    </div>

                                    @if (Model.EtiquetasDisponibles.Any())
                                    {
                                        <div class="row g-3">
                                            @foreach (var etiqueta in Model.EtiquetasDisponibles)
                                            {
                                                <div class="col-md-6 col-lg-4">
                                                    <div class="tag-option-card">
                                                        <div class="form-check m-0 d-flex align-items-center gap-2">
                                                            <input class="form-check-input"
                                                                   type="checkbox"
                                                                   name="SelectedEtiquetaIds"
                                                                   value="@etiqueta.EtiquetaID"
                                                                   id="etiqueta_@etiqueta.EtiquetaID"
                                                                   @(Model.SelectedEtiquetaIds.Contains(etiqueta.EtiquetaID) ? "checked" : null) />

                                                            <label class="form-check-label fw-semibold ms-1 d-flex align-items-center gap-2 flex-wrap"
                                                                   for="etiqueta_@etiqueta.EtiquetaID">
                                                                <span class="tag-color-dot" style="background-color:@etiqueta.ColorHex;"></span>
                                                                <span>@etiqueta.Nombre</span>
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-light border mb-0 rounded-4 empty-soft-box">
                                            No hay etiquetas activas registradas. Puedes crear el contacto ahora y luego asignarle etiquetas desde edición, o bien crear primero las etiquetas.
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-section-box">
                                    <div class="section-headline-wrap">
                                        <h2 class="form-section-title">Contacto</h2>
                                        <p class="section-support-text mb-0">Información principal de comunicación.</p>
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label asp-for="Input.TelefonoNumero" class="form-label fw-semibold">Teléfono</label>
                                            <input asp-for="Input.TelefonoNumero" class="form-control rounded-3" placeholder="Ej. 8888-8888" />
                                            <span asp-validation-for="Input.TelefonoNumero" class="text-danger small"></span>
                                        </div>

                                        <div class="col-md-6">
                                            <label asp-for="Input.TelefonoTipo" class="form-label fw-semibold">Tipo de teléfono</label>
                                            <input asp-for="Input.TelefonoTipo" class="form-control rounded-3" placeholder="Ej. Personal, Trabajo..." />
                                            <span asp-validation-for="Input.TelefonoTipo" class="text-danger small"></span>
                                        </div>

                                        <div class="col-12">
                                            <label asp-for="Input.Email" class="form-label fw-semibold">Correo</label>
                                            <input asp-for="Input.Email" class="form-control rounded-3" placeholder="correo@ejemplo.com" />
                                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-section-box">
                                    <div class="section-headline-wrap">
                                        <h2 class="form-section-title">Dirección</h2>
                                        <p class="section-support-text mb-0">Ubicación general del contacto.</p>
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <label asp-for="Input.Provincia" class="form-label fw-semibold"></label>
                                            <input asp-for="Input.Provincia" class="form-control rounded-3" />
                                        </div>

                                        <div class="col-md-4">
                                            <label asp-for="Input.Canton" class="form-label fw-semibold"></label>
                                            <input asp-for="Input.Canton" class="form-control rounded-3" />
                                        </div>

                                        <div class="col-md-4">
                                            <label asp-for="Input.Distrito" class="form-label fw-semibold"></label>
                                            <input asp-for="Input.Distrito" class="form-control rounded-3" />
                                        </div>

                                        <div class="col-12">
                                            <label asp-for="Input.DireccionExacta" class="form-label fw-semibold">Dirección exacta</label>
                                            <textarea asp-for="Input.DireccionExacta" class="form-control rounded-3" rows="3" placeholder="Detalle adicional de la dirección"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-section-box">
                                    <div class="section-headline-wrap">
                                        <h2 class="form-section-title">Información adicional</h2>
                                        <p class="section-support-text mb-0">Notas complementarias del contacto.</p>
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label asp-for="Input.NotaContenido" class="form-label fw-semibold">Nota</label>
                                            <textarea asp-for="Input.NotaContenido" class="form-control rounded-3" rows="4" placeholder="Agrega una nota si lo deseas"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex flex-column flex-sm-row justify-content-end gap-2 mt-4 pt-2 form-actions-bar">
                            <a asp-page="Index" class="btn btn-app-outline rounded-pill px-4">
                                Cancelar
                            </a>

                            <button type="submit" class="btn btn-app-primary rounded-pill px-4">
                                Guardar contacto
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}