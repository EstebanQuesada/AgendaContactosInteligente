@page "{id:int}"
@model AgendaContactosInteligente.Pages.Contactos.DeleteModel
@{
    ViewData["Title"] = "Eliminar contacto";
}

<div class="row justify-content-center py-2 py-lg-4">
    <div class="col-12 col-lg-8 col-xl-7">
        <div class="card">
            <div class="card-header py-4 px-4 px-lg-5">
                <div class="page-eyebrow">Gestión de contactos</div>
                <h1 class="page-title h3 text-danger">Eliminar contacto</h1>
            </div>

            <div class="card-body p-4 p-lg-5">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                <div class="section-card-soft mb-4">
                    <p class="section-title mb-2">Confirmación</p>
                    <p class="mb-0">
                        ¿Deseas eliminar el contacto
                        <strong>@Model.Contacto?.Nombre @Model.Contacto?.Apellido</strong>?
                        Esta acción desactivará el contacto y sus datos relacionados según los procedimientos almacenados.
                    </p>
                </div>

                <form method="post">
                    <div class="d-flex flex-column flex-sm-row justify-content-end gap-2">
                        <a asp-page="Details"
                           asp-route-id="@Model.Contacto?.ContactoID"
                           class="btn btn-outline-secondary px-4">
                            Cancelar
                        </a>

                        <button type="submit" class="btn btn-danger px-4">
                            Eliminar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>