@page "{id:int}"
@model AgendaContactosInteligente.Pages.Contactos.DeleteModel
@{
    ViewData["Title"] = "Eliminar contacto";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h2 class="h4 mb-0 text-danger">Eliminar contacto</h2>
                </div>

                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <p class="mb-4">
                        ¿Deseas eliminar el contacto
                        <strong>@Model.Contacto?.Nombre @Model.Contacto?.Apellido</strong>?
                        Esta acción desactivará el contacto y sus datos relacionados según los procedimientos almacenados.
                    </p>

                    <form method="post">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-page="Details"
                               asp-route-id="@Model.Contacto?.ContactoID"
                               class="btn btn-outline-secondary">
                                Cancelar
                            </a>

                            <button type="submit" class="btn btn-danger">
                                Eliminar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>