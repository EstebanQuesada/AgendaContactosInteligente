@page
@model AgendaContactosInteligente.Pages.Etiquetas.IndexModel
@{
    ViewData["Title"] = "Etiquetas";
}

<section class="page-section fade-up">
    <div class="page-header-card mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <div class="page-eyebrow">Etiquetas</div>
                <h1 class="page-title mb-1">Administración de etiquetas</h1>
                <p class="page-subtitle mb-0">
                    Crea, organiza y administra las etiquetas disponibles para clasificar tus contactos.
                </p>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-2">
                <a asp-page="/Etiquetas/Create" class="btn btn-app-primary">
                    Nueva etiqueta
                </a>
            </div>
        </div>

        <div class="quick-access-grid mt-4">
            <a asp-page="/Etiquetas/Create" class="quick-access-card">
                <div class="quick-access-icon qa-green">＋</div>
                <div>
                    <h3>Agregar etiqueta</h3>
                    <p>Registrar una nueva etiqueta para usar en tus contactos.</p>
                </div>
            </a>

            <a asp-page="/Etiquetas/Index" class="quick-access-card active">
                <div class="quick-access-icon qa-blue">#</div>
                <div>
                    <h3>Listado</h3>
                    <p>Ver y administrar las etiquetas registradas.</p>
                </div>
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success app-alert-success mb-4">
            @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger mb-4">
            @Model.ErrorMessage
        </div>
    }

    <div class="card app-card border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table app-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Etiqueta</th>
                            <th style="width: 180px;">Contactos asociados</th>
                            <th style="width: 200px;">Fecha creación</th>
                            <th class="text-end" style="width: 280px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Etiquetas.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <div class="empty-state-table">
                                        <div class="empty-state-icon">#</div>
                                        <div class="fw-semibold mb-1">No hay etiquetas registradas</div>
                                        <div class="small">Cuando agregues etiquetas aparecerán aquí.</div>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var etiqueta in Model.Etiquetas)
                            {
                                <tr>
                                    <td>
                                        <span class="badge rounded-pill px-3 py-2 fw-semibold"
                                              style="background-color:@etiqueta.ColorHex; color:#ffffff;">
                                            @etiqueta.Nombre
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge rounded-pill text-bg-light border px-3 py-2">
                                            @etiqueta.CantidadContactos
                                        </span>
                                    </td>

                                    <td class="text-muted">
                                        @etiqueta.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                    </td>

                                    <td class="text-end">
                                        <div class="d-flex justify-content-end flex-wrap gap-2">
                                            <a asp-page="/Contactos/Index"
                                               asp-route-EtiquetaId="@etiqueta.EtiquetaID"
                                               class="btn btn-sm btn-action btn-action-neutral">
                                                Ver contactos
                                            </a>

                                            <a asp-page="/Etiquetas/Edit"
                                               asp-route-id="@etiqueta.EtiquetaID"
                                               class="btn btn-sm btn-action btn-action-primary">
                                                Editar
                                            </a>

                                            <a asp-page="/Etiquetas/Delete"
                                               asp-route-id="@etiqueta.EtiquetaID"
                                               class="btn btn-sm btn-action btn-action-danger">
                                                Eliminar
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>