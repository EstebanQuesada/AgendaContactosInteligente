@page "{id:int}"
@model AgendaContactosInteligente.Pages.Etiquetas.DeleteModel
@{
    ViewData["Title"] = "Eliminar etiqueta";
}

<div class="container py-4 py-lg-5 fade-up">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-7">
            <div class="card app-card border-0">
                <div class="card-header app-detail-header py-4 px-4 px-lg-5">
                    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                        <div>
                            <div class="page-eyebrow">Gestión de etiquetas</div>
                            <h1 class="page-title h3 mb-1">Eliminar etiqueta</h1>
                            <p class="text-muted mb-0">
                                Esta acción desactivará la etiqueta y eliminará sus asociaciones actuales.
                            </p>
                        </div>

                        <a asp-page="Index" class="btn btn-app-outline px-4">
                            Volver
                        </a>
                    </div>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <div class="section-card">
                        <h2 class="section-title">Confirmación</h2>

                        <p class="mb-3">
                            ¿Deseas eliminar la siguiente etiqueta?
                        </p>

                        <div class="note-box mb-3">
                            <div><span class="fw-semibold">Nombre:</span> @Model.Etiqueta!.Nombre</div>
                            <div><span class="fw-semibold">Contactos asociados:</span> @Model.Etiqueta.CantidadContactos</div>
                        </div>

                        <div class="alert alert-warning mb-0">
                            Al confirmar, la etiqueta dejará de estar disponible y se quitarán sus asociaciones con los contactos.
                        </div>
                    </div>

                    <form method="post" class="mt-4 pt-2">
                        <div class="d-flex flex-column flex-sm-row justify-content-end gap-2">
                            <a asp-page="Index" class="btn btn-app-outline px-4">
                                Cancelar
                            </a>

                            <button type="submit" class="btn btn-danger px-4">
                                Eliminar etiqueta
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>